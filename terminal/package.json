{
  "name": "@code-agents/terminal",
  "version": "0.1.0",
  "description": "TypeScript terminal client for code-agents — Ink + oclif TUI consuming Python server over HTTP/SSE",
  "type": "module",
  "bin": {
    "code-agents-ts": "./bin/run.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "tsx bin/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "code-agents-ts",
    "dirname": "code-agents-ts",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@oclif/core": "^4.0.0",
    "@oclif/plugin-autocomplete": "^3.0.0",
    "@oclif/plugin-help": "^6.0.0",
    "chalk": "^5.3.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "react": "^18.3.0",
    "undici": "^7.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "license": "UNLICENSED"
}
